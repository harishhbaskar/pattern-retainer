export default function AddLearning() {
  const [topic, setTopic] = useState('');
  const [description, setDescription] = useState('');
  const router = useRouter();

  const handleSubmit = async () => {
    if (!topic) {
      Alert.alert('Missing Field', 'Please enter a topic');
      return;
