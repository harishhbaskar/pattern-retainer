import React, { useState, useCallback } from 'react';
import { View, Text, FlatList, TouchableOpacity, RefreshControl } from 'react-native';
import { useFocusEffect } from 'expo-router';
import { CheckCircle } from 'lucide-react-native';
import api from '../../utils/api';
import { format } from 'date-fns';

type Learning = {
  _id: string;
  topic: string;
  description: string;
  stage: number;
  nextReviewDate: string;
};

export default function Dashboard() {
  const [learnings, setLearnings] = useState<Learning[]>([]);
  const [refreshing, setRefreshing] = useState(false);

  const fetchLearnings = async () => {
    try {
      const { data } = await api.get('/learnings');
      // Filter for items due today or earlier
      const dueItems = data.filter((l: Learning) => new Date(l.nextReviewDate) <= new Date());
      setLearnings(dueItems);
    } catch (error) {
      console.error(error);
    }
  };

  const handleReview = async (id: string) => {
    try {
      await api.put(`/learnings/${id}/review`);
      fetchLearnings();
    } catch (error) {
      console.error(error);
    }
  };

  useFocusEffect(
    useCallback(() => {
      fetchLearnings();
    }, [])
  );

  const onRefresh = async () => {
    setRefreshing(true);
    await fetchLearnings();
    setRefreshing(false);
  };

  return (
    <View className="flex-1 bg-secondary p-4">
      <FlatList
        data={learnings}
        keyExtractor={(item) => item._id}
        refreshControl={
          <RefreshControl refreshing={refreshing} onRefresh={onRefresh} tintColor="#AB8BFF" />
        }
        ListEmptyComponent={
          <View className="flex-1 items-center justify-center mt-20">
            <Text className="text-light-300 text-lg">No reviews due today!</Text>
            <Text className="text-light-300 text-sm mt-2">Check back tomorrow.</Text>
          </View>
        }
        renderItem={({ item }) => (
          <View className="bg-dark-100 p-4 rounded-xl mb-4 border-l-4 border-accent">
            <View className="flex-row justify-between items-start mb-2">
              <View className="bg-dark-200 px-3 py-1 rounded-full">
                <Text className="text-accent font-bold text-xs">Stage {item.stage}</Text>
              </View>
              <Text className="text-light-300 text-xs">{format(new Date(item.nextReviewDate), 'MMM d')}</Text>
            </View>
            
            <Text className="text-white text-xl font-bold mb-1">{item.topic}</Text>
            <Text className="text-light-200 mb-4">{item.description}</Text>

            <TouchableOpacity 
              onPress={() => handleReview(item._id)}
              className="flex-row items-center justify-center bg-light-100/10 py-3 rounded-lg active:bg-light-100/20"
            >
              <CheckCircle size={18} color="#AB8BFF" />
              <Text className="text-accent font-bold ml-2">Mark Reviewed</Text>
            </TouchableOpacity>
          </View>
        )}
      />
    </View>
  );
}
</file>

